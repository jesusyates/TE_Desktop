# =============================================================================
# 本地「生产对齐」联调 — 唯一推荐基线（≈ 服务器 pm2 + dual_write + Supabase Auth）
# =============================================================================
# 使用：cp .env.local.example .env.local （.env.local 已 gitignore，勿提交）
# 加载顺序见 src/infra/config/bootstrap-env.js：.env → .env.${NODE_ENV} → .env.local
#
# 与旧模板差异：
# - 主认证源为 Supabase；不在此默认配置 AUTH_MAIL_SINK=smtp / Resend SMTP（邮件走 Supabase 控制台）
# - 主存储为 dual_write；不要用 memory 作为主联调默认
# =============================================================================

NODE_ENV=production
PORT=4000
API_BASE_URL=http://127.0.0.1:4000

TRUST_PROXY=true
STORAGE_MODE=dual_write

LOG_LEVEL=debug

# ----------------------------------------------------------------------------- 认证（唯一源：Supabase）
AUTH_PROVIDER=supabase

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# 密码恢复跳转（须同时配置在 Supabase Dashboard → Auth → URL）
AUTH_RECOVERY_REDIRECT_URL=http://127.0.0.1:5173/auth/reset

# 仅 legacy 链强依赖（≥16）；Supabase 主链可不用于签发，但填占位可避免误切 legacy 时过短
JWT_SECRET=
SHARED_CORE_AUTH_SECRET=

# ----------------------------------------------------------------------------- CORS（生产 REQUIRED；对齐桌面 null / file / Vite）
# 勿在逗号前后加空格；可含字面量 null、file://
ALLOWED_ORIGINS=null,file://,http://localhost:5173,http://127.0.0.1:5173
# CORS_STRICT=1

# ----------------------------------------------------------------------------- Legacy SQLite bootstrap（主联调 supabase 不必启用）
# 代码中无 AUTH_BOOTSTRAP_ENABLED / AUTH_BOOTSTRAP_NAME；应急开关名称为：
# AUTH_LEGACY_BOOTSTRAP_ENABLE=1（仅 AUTH_PROVIDER=legacy 且生产时）
AUTH_LEGACY_BOOTSTRAP_ENABLE=
AUTH_BOOTSTRAP_EMAIL=admin@example.com
AUTH_BOOTSTRAP_PASSWORD=
# AUTH_BOOTSTRAP_MARKET=global
# AUTH_BOOTSTRAP_LOCALE=en-US

# ----------------------------------------------------------------------------- 邮件边界（必读）
# AUTH_PROVIDER=supabase 时：注册/验证邮件由 Supabase Auth（你在控制台接 Resend 等）发送；本仓库 Core 的
# auth.mailer / AUTH_SMTP_* 不会作为主路径，且生产启动校验已对 supabase 跳过 SMTP 必填。
#
# 下列为历史 legacy / 特殊调试用途；「本地生产对齐」默认请保持注释，勿把 smtp 当默认：
# AUTH_MAIL_SINK=none
# AUTH_SMTP_HOST=
# AUTH_SMTP_PORT=587
# AUTH_SMTP_USER=
# AUTH_SMTP_PASS=
# AUTH_SMTP_SECURE=false
# AUTH_MAIL_FROM=

# ----------------------------------------------------------------------------- 其它（可选）
# OPENAI_API_KEY=
# AI_ROUTER_BASE_URL=
# AI_ROUTER_API_KEY=
