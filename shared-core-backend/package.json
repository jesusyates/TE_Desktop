{
  "name": "shared-core-backend",
  "version": "1.2.0",
  "type": "commonjs",
  "private": true,
  "description": "Shared Core — unified backend (Web / Desktop / Mobile). Express entry, layered architecture, SQLite C-7.",
  "main": "src/main.js",
  "scripts": {
    "validate:boot": "node scripts/validate-boot.js",
    "start": "node src/main.js",
    "dev": "cross-env NODE_ENV=development node --watch src/main.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop shared-core-backend",
    "pm2:restart": "pm2 restart shared-core-backend"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "nodemailer": "^6.10.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3"
  }
}
